# CDP Environment (dev, qa, prod)
CDP_ENVIRONMENT=dev

# Base URLs per environment (override if needed)
CDP_BASE_URL_DEV=https://dev-api6.agilone.com
CDP_BASE_URL_QA=https://qa-api6.agilone.com
CDP_BASE_URL_PROD=https://api.agilone.com

# Default tenant ID (can be overridden per-tool-call)
CDP_TENANT_ID=

# OAuth2 Credentials (for token generation)
CDP_CLIENT_ID=
CDP_CLIENT_SECRET=
CDP_USERNAME=
CDP_PASSWORD=

# Pre-existing bearer token (alternative to OAuth2 flow)
CDP_AUTH_TOKEN=
